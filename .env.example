# ── Copy this file to .env and fill in your values ──────────────────
# cp .env.example .env

# ── Security ─────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=False

# ── Database (PostgreSQL) ─────────────────────────────────────────────
# Local PostgreSQL:
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/weblance_db

# AWS RDS PostgreSQL:
DATABASE_URL=postgresql://weblance_user:yourpassword@your-rds-endpoint.rds.amazonaws.com:5432/weblance_db

# Enable SSL for AWS RDS (recommended in production)
DB_SSL=True

# ── Allowed Hosts ─────────────────────────────────────────────────────
# Comma-separated list of your domains/IPs
# Example: ALLOWED_HOSTS=weblance.in,www.weblance.in,your-ec2-ip
ALLOWED_HOSTS=weblance.in,www.weblance.in

# ── Render.com (if deploying to Render) ──────────────────────────────
# RENDER_EXTERNAL_HOSTNAME=your-app.onrender.com

# ── Email (Gmail SMTP) ────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=infoweblance01@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# ── Site URL (for QR codes in PDFs) ──────────────────────────────────
SITE_URL=https://weblance.in

# ── Gemini AI ─────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
